<!DOCTYPE html>
  <html lang="en"> 
  <head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Personal website of Lena Kujath. The site showcases ongoing projects and provides some 
      information about the site authors background and interests.">
    <title>Lena Kujath</title>
    <link rel="stylesheet" type="text/css" href="../css/bundle.css">
    <link rel="icon" type="image/x-icon" href="../../images/favicon.svg">
  </head>
  <body>
      {% include "partials/header.njk" %}
      <main>
      <header id="hero">
        <nav class="nav">
          <ul class="nav-links">
            {% for item in nav.pages %}
            <li>
              <a href="{{ item.url }}" {{ helpers.getLinkActiveState(item.url, page.url) | safe }}>
                <span>{{ item.label }}</span>
              </a>
            </li>
            {% endfor %}
          </ul>
        </nav>
        <div class="title">
          {{ content | safe }}
        </div>
    </header>
      </main>
      {% include "partials/footer.njk" %}
      <script src="/bundle.js"></script>
  </body>
</html>